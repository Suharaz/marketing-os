DATABASE_URL=postgresql://marketing:devpass@localhost:5433/marketing_os
SESSION_PASSWORD=change_me_min_32_chars_long_secret
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=http://localhost:3000/api/auth/fb/callback
ENCRYPTION_KEY=change_me_32_byte_hex_for_pgcrypto
ADMIN_EMAIL=admin@taki.vn
ADMIN_PASSWORD_HASH=
NODE_ENV=development
# Canonical app URL — used for building absolute URLs (FB OAuth redirect, etc.)
APP_URL=http://localhost:3000
# Exposed to browser via Next.js NEXT_PUBLIC_ prefix
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Ladipage / n8n webhook — required for landing_page_conversion sync
# (Job D cron at 23:30 VN + manual sync piggyback). Without these, every
# Ladipage call fails with "env vars are required" and conversion data
# never lands in the DB.
LADIPAGE_WEBHOOK_URL=https://n8nauto.nguyentatkiem.com/webhook/cooking-ladipage-data
LADIPAGE_API_KEY=
